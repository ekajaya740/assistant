# OpenClaw Environment Schema
# @env-spec for varlock - AI-safe environment variable management
# @currentEnv=$APP_ENV
# @defaultSensitive=false @defaultRequired=false
# @generateTypes(lang=ts, path=env.d.ts)
# ---

# ---
# Gateway Configuration
# ---

# Gateway authentication token
# @required @sensitive
OPENCLAW_GATEWAY_TOKEN=

# Gateway bind address (lan, localhost, or 0.0.0.0)
# @type=enum("lan", "localhost", "0.0.0.0")
OPENCLAW_GATEWAY_BIND=lan

# Gateway HTTP port
# @type=number(min=1024, max=65535)
OPENCLAW_GATEWAY_PORT=18789

# Bridge WebSocket port
# @type=number(min=1024, max=65535)
OPENCLAW_BRIDGE_PORT=18790

# Allow insecure private WebSocket connections
# @type=boolean
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=false

# ---
# AI Provider Configuration
# Use either OpenAI-compatible API OR direct Claude API
# ---

# Option 1: OpenAI-Compatible API (Recommended - works with OpenAI, OpenRouter, Ollama, etc.)
# @sensitive
OPENAI_API_KEY=

# Base URL for OpenAI-compatible API
# @examples=https://api.openai.com/v1,https://openrouter.ai/api/v1,http://localhost:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Model name for OpenAI-compatible API
# @examples=gpt-4o,anthropic/claude-3.5-sonnet,llama3.1
OPENAI_MODEL=gpt-4o

# Optional: Organization ID (OpenAI only)
OPENAI_ORG_ID=

# Option 2: Direct Claude API (Legacy - use OpenAI-compatible instead)
# @sensitive
CLAUDE_AI_SESSION_KEY=

# Claude web session key
# @sensitive
CLAUDE_WEB_SESSION_KEY=

# Claude web cookie for authentication
# @sensitive
CLAUDE_WEB_COOKIE=

# ---
# Paths and Directories
# ---

# OpenClaw configuration directory (absolute path required)
# @required @type=path
OPENCLAW_CONFIG_DIR=

# OpenClaw workspace directory (absolute path required)
# @required @type=path
OPENCLAW_WORKSPACE_DIR=

# Docker image to use for CLI
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:main

# ---
# System Configuration
# ---

# Timezone for the container
# @type=string
OPENCLAW_TZ=UTC

# Docker group ID for sandbox isolation
# @type=number
DOCKER_GID=999
